{
  "name": "official-site",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "typecheck": "turbo run check-types",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write . && bun run typecheck",
    "clean": "turbo run clean --ui=stream && bunx rimraf .turbo",
    "ci": "biome ci . && bun run typecheck",
    "clean:all": "bun run clean && rm -rf node_modules apps/*/node_modules packages/*/node_modules .turbo",
    "compress:gallery": "node scripts/compress-gallery.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@pandacss/dev": "^1.9.0",
    "bun-types": "^1.3.11",
    "sharp": "^0.34.4",
    "turbo": "^2.8.20",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "lefthook": "^2.1.4",
    "official-site": "."
  }
}
