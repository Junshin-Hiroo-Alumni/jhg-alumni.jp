{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "prepare": {
      "inputs": ["panda.config.ts"],
      "outputs": ["styled-system/**"],
      "cache": true
    },
    "build": {
      "dependsOn": ["^build", "prepare"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "build/**", "dist/**"]
    },
    "check-types": {
      "dependsOn": ["^check-types", "prepare"]
    },
    "dev": {
      "dependsOn": ["prepare"],
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false,
      "outputs": []
    }
  }
}
