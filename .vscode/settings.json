{
  "editor.defaultFormatter": "biomejs.biome",
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.biome": "explicit",
    "source.organizeImports.biome": "explicit"
  },
  "editor.tabSize": 2,
  "editor.insertSpaces": false,
  "editor.detectIndentation": false,
  "files.eol": "\n",
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,
  "files.exclude": {
    "**/node_modules": true,
    "dist": true,
    "apps/web/dist": true,
    "**/.turbo": true,
    "**/bun.lock": true,
    "**/tanstack": true,
    "**/styled-system": true,
    "**/.react-router": true,
    "**/generated": true
  },
  "[typescript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[json]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2
  },
  "[yaml]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2
  },
  "search.exclude": {
    "**/node_modules": true,
    "dist": true,
    "apps/web/dist": true,
    "**/.turbo": true,
    "**/bun.lock": true,
    "**/tanstack": true,
    "**/styled-system": true,
    "**/.react-router": true,
    "**/generated": true
  }
}
